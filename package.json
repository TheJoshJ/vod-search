{
  "name": "vod-search",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.15.1",
  "scripts": {
    "dev": "pnpm --filter @vod-search/desktop dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:search:hybrid": "pnpm --filter @vod-search/desktop exec electron ../../scripts/evaluate-live-hybrid-search.cjs",
    "test:search:live": "pnpm --filter @vod-search/desktop exec electron ../../scripts/evaluate-live-search.cjs",
    "test:watch": "vitest",
    "prepare:runtimes:win": "tsx scripts/fetch-windows-runtimes.ts",
    "package:win": "pnpm prepare:runtimes:win && pnpm --filter @vod-search/desktop package:win",
    "release:win": "pnpm prepare:runtimes:win && pnpm --filter @vod-search/desktop release:win"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "extract-zip": "2.0.1",
    "pnpm": "11.15.1",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "vitest": "4.1.0"
  }
}

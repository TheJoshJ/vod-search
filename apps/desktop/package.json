{
  "name": "@vod-search/desktop",
  "version": "0.1.0",
  "description": "Private local search for timestamped video transcripts",
  "author": "VOD Search contributors",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "predev": "install-electron --no && electron-rebuild -v 43.1.1 -f -w better-sqlite3",
    "dev": "electron-vite dev",
    "dev:renderer": "vite --config vite.renderer.config.ts",
    "build": "electron-vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "package:win": "pnpm build && electron-builder --win nsis --x64 --publish never",
    "release:win": "pnpm build && electron-builder --win nsis --x64 --publish always"
  },
  "dependencies": {
    "@fontsource-variable/lora": "^5.3.0",
    "@fontsource-variable/plus-jakarta-sans": "^5.3.0",
    "@fontsource/ibm-plex-mono": "^5.3.0",
    "@huggingface/transformers": "4.2.0",
    "@radix-ui/react-dialog": "^1.1.20",
    "@radix-ui/react-select": "^2.3.4",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.4",
    "@radix-ui/react-tabs": "^1.1.18",
    "@radix-ui/react-tooltip": "^1.2.13",
    "@vod-search/contracts": "workspace:*",
    "@vod-search/database": "workspace:*",
    "@vod-search/inference": "workspace:*",
    "@vod-search/search": "workspace:*",
    "better-sqlite3": "12.11.1",
    "chokidar": "5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.9",
    "lucide-react": "^1.25.0",
    "radix-ui": "^1.6.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sqlite-vec": "0.1.9",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@electron/rebuild": "4.2.0",
    "@tailwindcss/vite": "^4.3.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "electron": "43.1.1",
    "electron-builder": "26.15.3",
    "electron-vite": "5.0.0",
    "tailwindcss": "^4.3.3",
    "vite": "7.3.6"
  },
  "build": {
    "appId": "com.vodsearch.desktop",
    "productName": "VOD Search",
    "publish": [
      {
        "provider": "github",
        "owner": "TheJoshJ",
        "repo": "vod-search",
        "releaseType": "release"
      }
    ],
    "directories": {
      "output": "../../release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../../resources/runtime",
        "to": "runtime",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asarUnpack": [
      "**/*.node",
      "**/node_modules/onnxruntime-node/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    }
  }
}

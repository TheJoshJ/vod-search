{
  "name": "@vod-search/desktop",
  "version": "0.1.0",
  "description": "Private local search for timestamped video transcripts",
  "author": "VOD Search contributors",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "package:win": "corepack pnpm build && electron-builder --win nsis --x64"
  },
  "dependencies": {
    "@huggingface/transformers": "4.2.0",
    "@opencode-ai/sdk": "1.18.4",
    "@vod-search/contracts": "workspace:*",
    "@vod-search/database": "workspace:*",
    "@vod-search/inference": "workspace:*",
    "@vod-search/search": "workspace:*",
    "better-sqlite3": "12.11.1",
    "chokidar": "5.0.0",
    "opencode-ai": "1.18.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sqlite-vec": "0.1.9",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "electron": "43.1.1",
    "electron-builder": "26.15.3",
    "electron-vite": "5.0.0",
    "vite": "7.3.6"
  },
  "build": {
    "appId": "com.vodsearch.desktop",
    "productName": "VOD Search",
    "directories": {
      "output": "../../release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../../resources/runtime",
        "to": "runtime",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asarUnpack": [
      "**/*.node",
      "**/node_modules/onnxruntime-node/**/*",
      "**/node_modules/opencode-ai/bin/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    }
  }
}
